# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (Settings → API → anon public)
SUPABASE_KEY=your-anon-key

# Supabase service role key (Settings → API → service_role) — keep secret
SUPABASE_SECRET_KEY=your-service-role-key

# Comma-separated frontend URLs allowed to call the API (set after Vercel deploy)
# Example: https://your-admin.vercel.app,https://your-customer.vercel.app
CORS_ORIGINS=*
